<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ProjetoBA - GitHub Clone</title>
    <link rel="stylesheet" href="styles.css">
    </head>
<body>
    <div class="container">
        <aside class="sidebar">
            <div class="repo-list">
                <h3>Top repositories</h3>
                <ul>
                    <li class="active">brenosiqueira2804-art/ProjetoBA</li>
                    <li>Allanbrazzy/cb</li>
                    </ul>
            </div>
        </aside>

        <main class="main-content">
            <header class="repo-header">
                <h1>
                    <span class="icon">📁</span>
                    ProjetoBA
                    <span class="public-badge">Public</span>
                </h1>
                </header>

            <div class="file-list">
                <div class="commit-summary">
                    </div>
                <div class="file-item file-header">
                    <span class="file-name">Nome do Arquivo/Pasta</span>
                    <span class="commit-message">Mensagem do Último Commit</span>
                    <span class="commit-date">Idade do Commit</span>
                </div>
                <div class="file-item">
                    <span class="file-name">Controllers</span>
                    <span class="commit-message">Subindo atualizações do projeto</span>
                    <span class="commit-date">37 minutes ago</span>
                </div>
                </div>
        </main>
    </div>
</body>
</html>